# GitHub Actions Variables & Local Configuration (non-sensitive)
# Copy to .env for local development, or to .staging.env / .production.env for CI.
# See docs/ci.md for the env file naming convention.

# -------------------------------------------------------
# Cloud provider CLI profiles (used by the iac container)
# The iac container mounts ~/.aws as read-only.
# Set the profile variable below so Terraform can locate your credentials.
# -------------------------------------------------------

# AWS SSO profile name. Run `aws configure list-profiles` to list available profiles.
# Required when using AWS SSO (`aws sso login --profile <name>`).
# Leave commented out if using long-lived IAM credentials (~/.aws/credentials).
#AWS_PROFILE=

# -------------------------------------------------------
# AWS
# -------------------------------------------------------

# IAM role ARN with GitHub OIDC trust policy (used for IaC).
AWS_IAM_ROLE_ARN=arn:aws:iam::123456789012:role/github-actions-iac

# S3 bucket name for Terraform state storage.
AWS_TF_STATE_BUCKET=my-terraform-state

# AWS region where the S3 state bucket is located.
AWS_TF_STATE_REGION=us-east-1

# -------------------------------------------------------
# Terraform variable mappings (TF_VAR_*)
# These map the provider-specific variables above to Terraform input variable names.
# Used by the iac container (via env_file) and GitHub Actions workflows (via env).
# -------------------------------------------------------
TF_VAR_aws_region=us-east-1
TF_VAR_aws_tf_state_bucket=my-terraform-state
TF_VAR_aws_tf_state_region=us-east-1

# -------------------------------------------------------
# App
# -------------------------------------------------------

# Unique prefix for all cloud resource names.
TF_VAR_app_unique_id=my-infra

# AZ ID for the Mac dedicated host (consistent across accounts).
TF_VAR_ec2_mac_availability_zone_id=use1-az4

# WorkSpaces bundle ID. Find with: aws workspaces describe-workspace-bundles --owner AMAZON
# us-east-1: wsb-xnp4cfzht (Value with Ubuntu 22.04)
TF_VAR_workspace_bundle_id=wsb-xnp4cfzht
